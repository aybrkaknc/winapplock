<Window x:Class="WinAppLock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinAppLock.UI.Views"
        Title="WinAppLock"
        Width="900" Height="620"
        MinWidth="750" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Border x:Name="WindowBorder"
            Background="{StaticResource BrushBackgroundDarkest}"
            CornerRadius="{StaticResource RadiusLarge}"
            BorderBrush="{StaticResource BrushBorderDefault}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <!-- Başlık Çubuğu -->
                <RowDefinition Height="44" />
                <!-- Ana İçerik -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════ -->
            <!-- Title Bar Area                          -->
            <!-- ═══════════════════════════════════════ -->
            <Grid x:Name="TitleBar" Grid.Row="0"
                  Background="{StaticResource BrushBackgroundDark}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo ve Uygulama Adı -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="16,0,0,0" VerticalAlignment="Center">
                    <!-- Kilit ikonu (Unicode) -->
                    <TextBlock x:Name="TitleBarIcon" Text="🔒"
                               FontSize="16" Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="TitleBarText" Text="WinAppLock"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="TitleBarVersion" Text="v0.0.100"
                               Foreground="{StaticResource BrushTextMuted}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXS}"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Pencere Kontrolleri -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Margin="0,0,8,0" VerticalAlignment="Center">
                    <Button x:Name="BtnMinimize" Content="─"
                            Style="{StaticResource BtnIcon}"
                            Click="BtnMinimize_Click"
                            ToolTip="Küçült" />
                    <Button x:Name="BtnClose" Content="✕"
                            Style="{StaticResource BtnIcon}"
                            Click="BtnClose_Click"
                            ToolTip="System Tray'e Küçült" />
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════ -->
            <!-- Main Content Area                       -->
            <!-- ═══════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Sol Menü -->
                    <ColumnDefinition Width="200" />
                    <!-- Ana İçerik -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ─── Sidebar Menu ─── -->
                <Border x:Name="SidebarPanel" Grid.Column="0"
                        Background="{StaticResource BrushBackgroundDark}"
                        BorderBrush="{StaticResource BrushDivider}"
                        BorderThickness="0,0,1,0">

                    <DockPanel LastChildFill="False">
                        <!-- Menü Öğeleri (Üst) -->
                        <StackPanel DockPanel.Dock="Top" Margin="8,12,8,0">
                            <Button x:Name="BtnNavDashboard"
                                    Content="📋  Dashboard"
                                    Style="{StaticResource BtnSecondary}"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,2" Padding="12,10"
                                    Click="BtnNavDashboard_Click" />
                            <Button x:Name="BtnNavSettings"
                                    Content="⚙️  Ayarlar"
                                    Style="{StaticResource BtnSecondary}"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,2" Padding="12,10"
                                    Click="BtnNavSettings_Click" />
                        </StackPanel>

                        <!-- Alt Kısım: Durum ve LockAll -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                            <!-- Servis Durum Göstergesi -->
                            <Border x:Name="ServiceStatusPanel"
                                    Background="{StaticResource BrushBackgroundMedium}"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="10,8" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="ServiceStatusDot"
                                             Width="8" Height="8"
                                             Fill="{StaticResource BrushStatusSuccess}"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center" />
                                    <TextBlock x:Name="ServiceStatusText"
                                               Text="Servis Aktif"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               FontSize="{StaticResource FontSizeS}" />
                                </StackPanel>
                            </Border>

                            <!-- Tümünü Kilitle Butonu -->
                            <Button x:Name="BtnLockAll"
                                    Content="🔐  Tümünü Kilitle"
                                    Style="{StaticResource BtnPrimary}"
                                    HorizontalContentAlignment="Center"
                                    Click="BtnLockAll_Click"
                                    ToolTip="Ctrl+Alt+L" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ─── Dashboard Content ─── -->
                <Grid x:Name="DashboardContent" Grid.Column="1" Margin="24,16,24,16">
                    <Grid.RowDefinitions>
                        <!-- Header: Başlık + Ekle -->
                        <RowDefinition Height="Auto" />
                        <!-- App List -->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- ─── Dashboard Header ─── -->
                    <Grid x:Name="DashboardHeader" Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="HeaderTitle" Text="Kilitli Uygulamalar"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeXL}"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="HeaderSubtitle" Text="0 uygulama korunuyor"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <Button x:Name="BtnAddApp" Grid.Column="1"
                                Content="＋  Uygulama Ekle"
                                Style="{StaticResource BtnPrimary}"
                                Click="BtnAddApp_Click"
                                ToolTip="Yeni bir uygulamayı kilitle" />
                    </Grid>

                    <!-- ─── Locked Apps List ─── -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="AppListPanel"
                                    AllowDrop="True"
                                    Drop="AppListPanel_Drop"
                                    DragOver="AppListPanel_DragOver">

                            <!-- ─── Empty State ─── -->
                            <Border x:Name="EmptyStatePanel"
                                    Visibility="Visible"
                                    Style="{StaticResource CardPanel}"
                                    Padding="40"
                                    Margin="0,40,0,0"
                                    HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="EmptyStateIcon" Text="🛡️"
                                               FontSize="48"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,16" />
                                    <TextBlock x:Name="EmptyStateTitle"
                                               Text="Henüz kilitli uygulama yok"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="{StaticResource FontSizeLG}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="EmptyStateDescription"
                                               Text="Korumak istediğin uygulamayı eklemek için&#x0a;yukarıdaki 'Uygulama Ekle' butonuna tıkla&#x0a;veya bir .exe dosyasını buraya sürükle-bırak."
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               FontFamily="{StaticResource FontPrimary}"
                                               FontSize="{StaticResource FontSizeMD}"
                                               TextAlignment="Center"
                                               Margin="0,8,0,16"
                                               LineHeight="22" />
                                    <Button x:Name="BtnEmptyStateAdd"
                                            Content="＋  İlk Uygulamayı Ekle"
                                            Style="{StaticResource BtnPrimary}"
                                            HorizontalAlignment="Center"
                                            Click="BtnAddApp_Click" />
                                </StackPanel>
                            </Border>

                            <!-- Uygulama kartları buraya dinamik olarak eklenir -->

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ─── Settings Content (SettingsView UserControl) ─── -->
                <Grid x:Name="SettingsContent" Grid.Column="1"
                      Visibility="Collapsed" Margin="24,16,24,16">
                    <local:SettingsView x:Name="SettingsViewControl" />
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
