<Window x:Class="WinAppLock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinAppLock.UI.Views"
        Title="WinAppLock"
        Width="800" Height="550"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Border x:Name="WindowBorder"
            Background="{StaticResource BrushRetroFace}"
            BorderThickness="2"
            BorderBrush="{StaticResource BrushRetroHighlight}"
            ClipToBounds="True">

        <Border BorderThickness="1,1,2,2" BorderBrush="{StaticResource BrushRetroShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Başlık Çubuğu (Title Bar) -->
                    <RowDefinition Height="26" />
                    <!-- Ana İçerik (Tabs) -->
                    <RowDefinition Height="*" />
                    <!-- Status Bar (Bilgi) -->
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>

                <!-- ─── Title Bar (Windows 98 Style) ─── -->
                <Grid x:Name="TitleBar" Grid.Row="0" Margin="2,2,2,0"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource RetroTitleActiveStart}" Offset="0" />
                            <GradientStop Color="{StaticResource RetroTitleActiveEnd}" Offset="1" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Icons/lock.png" Width="16" Height="16" Margin="4,0,4,0" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                        <TextBlock Text="WinAppLock" 
                                   Foreground="White" 
                                   FontFamily="{StaticResource FontRetro}" 
                                   FontSize="{StaticResource FontSizeTitle}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Windows 98 Pencere Butonları -->
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,2,2,2">
                        <Button x:Name="BtnMinimize" Content="0" FontFamily="Marlett" FontSize="10"
                                Style="{StaticResource BtnRetro}" Padding="4,0" Width="16" Height="14"
                                Click="BtnMinimize_Click" Margin="0,0,2,0" />
                        <Button x:Name="BtnClose" Content="r" FontFamily="Marlett" FontSize="10"
                                Style="{StaticResource BtnRetro}" Padding="4,0" Width="16" Height="14"
                                Click="BtnClose_Click" />
                    </StackPanel>
                </Grid>

                <!-- ─── Main Content (Retro Tabbed Layout) ─── -->
                <TabControl Grid.Row="1" Style="{StaticResource RetroTabs}" Margin="4">
                    
                    <!-- 1. DASHBOARD -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Assets/Icons/computer.png" Width="16" Height="16" Margin="0,0,4,0" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                <TextBlock Text="{DynamicResource Str_Dashboard}" />
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Background="{StaticResource BrushRetroFace}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BrushRetroShadow}" Margin="0,0,0,10" Padding="0,0,0,10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{DynamicResource Str_LockedApps}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="Black" />
                                        <TextBlock x:Name="RunAppCountText" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#555">
                                            <Run Text="(" /><Run x:Name="RunAppCountValue" Text="0" /><Run Text=" " /><Run Text="{DynamicResource Str_AppCount}" /><Run Text=")" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Button x:Name="BtnAddApp" HorizontalAlignment="Right" Content="{DynamicResource Str_BtnAddApp}" Style="{StaticResource BtnRetro}" Click="BtnAddApp_Click" />
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="AppListPanel" 
                                            AllowDrop="True" Drop="AppListPanel_Drop" DragOver="AppListPanel_DragOver">
                                    
                                    <!-- Empty State (Win98 Style Help Box) -->
                                    <Border x:Name="EmptyStatePanel" Visibility="Visible" Margin="40" Padding="20"
                                            BorderThickness="1" BorderBrush="{StaticResource BrushRetroShadow}" Background="White">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="🛡️" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10" />
                                            <TextBlock Text="{DynamicResource Str_EmptyStateTitle}" FontWeight="Bold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{DynamicResource Str_EmptyStateDesc}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- 2. AYARLAR -->
                    <TabItem Header="{DynamicResource Str_Settings}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <local:SettingsView x:Name="SettingsViewControl" />
                        </ScrollViewer>
                    </TabItem>

                    <!-- 3. LOGLAR (İleride Eklenecek) -->
                    <TabItem Header="{DynamicResource Str_History}" IsEnabled="False">
                        <TextBlock Text="Access history logging coming soon in v0.0.103" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#888" />
                    </TabItem>
                </TabControl>

                <!-- ─── Status Bar ─── -->
                <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BrushRetroHighlight}">
                    <Grid Background="{StaticResource BrushRetroFace}" Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" BorderThickness="1" BorderBrush="{StaticResource BrushRetroShadow}" Padding="4,1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ServiceStatusDot" Width="8" Height="8" Fill="Green" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock x:Name="ServiceStatusText" Text="{DynamicResource Str_ServiceActive}" FontSize="10" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" BorderThickness="1" BorderBrush="{StaticResource BrushRetroShadow}" Padding="4,1" Margin="4,0,0,0" Width="100">
                            <TextBlock Text="v0.0.103.2" FontSize="10" HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
