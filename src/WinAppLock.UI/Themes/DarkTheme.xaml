<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- WinAppLock DARK-RETRO (Windows 98) Tema Sözlüğü     -->
    <!-- 98.css mantığıyla Modern-Retro bir deneyim.         -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- ─── Renk Paleti (Dark Retro Modeli) ─── -->
    <!-- Klasik gri tonlarının koyu füme/lacivert yorumu -->
    <Color x:Key="RetroFace">#2C2C2C</Color>
    <Color x:Key="RetroHighlight">#4A4A4A</Color>
    <Color x:Key="RetroShadow">#141414</Color>
    <Color x:Key="RetroBlack">#000000</Color>
    <Color x:Key="RetroWhite">#555555</Color> <!-- Modern retroda beyaz yerine açık gri -->

    <Color x:Key="RetroWindowBody">#1E1E1E</Color>
    <Color x:Key="RetroInputBackground">#FFFFFF</Color> <!-- Inputlar klasik beyaz kalabilir veya koyu olabilir -->
    <Color x:Key="RetroInputText">#000000</Color>

    <!-- Başlık Çubuğu Gradyan Karışımı -->
    <Color x:Key="RetroTitleActiveStart">#000080</Color>
    <Color x:Key="RetroTitleActiveEnd">#1084D0</Color>
    <Color x:Key="RetroTitleText">#FFFFFF</Color>

    <!-- ─── SolidColorBrush Tanımları ─── -->
    <SolidColorBrush x:Key="BrushRetroFace" Color="{StaticResource RetroFace}" />
    <SolidColorBrush x:Key="BrushRetroHighlight" Color="{StaticResource RetroHighlight}" />
    <SolidColorBrush x:Key="BrushRetroShadow" Color="{StaticResource RetroShadow}" />
    <SolidColorBrush x:Key="BrushRetroWindowBody" Color="{StaticResource RetroWindowBody}" />
    <SolidColorBrush x:Key="BrushRetroInputBackground" Color="{StaticResource RetroInputBackground}" />
    <SolidColorBrush x:Key="BrushRetroInputText" Color="{StaticResource RetroInputText}" />
    <SolidColorBrush x:Key="BrushRetroTitleText" Color="{StaticResource RetroTitleText}" />

    <!-- ─── Tipografi (Hi-DPI Tahoma) ─── -->
    <FontFamily x:Key="FontRetro">Tahoma, MS Sans Serif, Segoe UI</FontFamily>
    <system:Double x:Key="FontSizeNormal">11</system:Double>
    <system:Double x:Key="FontSizeTitle">12</system:Double>

    <!-- ─── Kenarlık Stilleri (3D Bevel) ─── -->
    <!-- Raised (Çıkıntılı) - Butonlar ve Pencereler için -->
    <Style x:Key="RetroBorderRaised" TargetType="Border">
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource RetroHighlight}" Offset="0" />
                    <GradientStop Color="{StaticResource RetroShadow}" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── BUTON STİLİ (Windows 98 Sunken Animation) ─── -->
    <Style x:Key="BtnRetro" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushRetroFace}" />
        <Setter Property="Foreground" Value="#000000" /> <!-- Klasik siyah metin -->
        <Setter Property="FontFamily" Value="{StaticResource FontRetro}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Dış Çerçeve (3D Efekti) -->
                        <Border x:Name="OuterBorder"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BrushRetroShadow}">
                            <Border x:Name="InnerBorder"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BrushRetroHighlight}"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter x:Name="Content"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover Durumu -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <!-- Win98'de hover efekti çok azdır, genelde belirtilmez ama biz doku ekleyebiliriz -->
                        </Trigger>
                        <!-- Sunken (Basılma) Animasyonu -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource BrushRetroHighlight}" />
                            <Setter TargetName="InnerBorder" Property="BorderBrush" Value="{StaticResource BrushRetroShadow}" />
                            <Setter TargetName="Content" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform X="1" Y="1" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── TABCONTROL STİLİ (Win98 Property Sheets) ─── -->
    <Style x:Key="RetroTabs" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TabPanel IsItemsHost="True" Grid.Row="0" Panel.ZIndex="1" Margin="0,0,4,-1" />
                        <Border Grid.Row="1" Background="{StaticResource BrushRetroFace}"
                                BorderThickness="2" BorderBrush="{StaticResource BrushRetroHighlight}"
                                SnapsToDevicePixels="True">
                            <Border BorderThickness="1,1,2,2" BorderBrush="{StaticResource BrushRetroShadow}">
                                <ContentPresenter ContentSource="SelectedContent" Margin="10" />
                            </Border>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder"
                            Background="{StaticResource BrushRetroFace}"
                            BorderThickness="1,1,1,0"
                            BorderBrush="{StaticResource BrushRetroHighlight}"
                            Padding="12,4" Margin="0,0,2,0"
                            CornerRadius="2,2,0,0">
                        <ContentPresenter ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Margin" Value="-2,-2,-2,-1" />
                            <Setter TargetName="TabBorder" Property="Padding" Value="14,6" />
                            <Setter Property="Panel.ZIndex" Value="10" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── ICON BUTTON STİLİ (Win98 Style) ─── -->
    <Style x:Key="BtnIcon" TargetType="Button" BasedOn="{StaticResource BtnRetro}">
        <Setter Property="Padding" Value="2" />
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="Height" Value="24" />
    </Style>

    <!-- ─── TOGGLESWITCH (Win98 CheckBox Style for ToggleButton) ─── -->
    <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- Check Box (Sunken) -->
                        <Border x:Name="Box" Grid.Column="0" Width="13" Height="13"
                                Background="White" BorderThickness="1" SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{StaticResource RetroShadow}" />
                            </Border.BorderBrush>
                            <TextBlock x:Name="CheckMark" Text="✓" Foreground="Black" 
                                       FontSize="10" FontWeight="Bold" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed" Margin="0,-1,0,0" />
                        </Border>
                        <ContentPresenter Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource BrushRetroFace}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
