<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- WinAppLock Karanlık Tema Kaynak Sözlüğü             -->
    <!-- Tüm renk, font, boyut ve stil tanımları burada.     -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- ─── Renk Paleti ─── -->
    <!-- Ana arkaplan tonları (koyu → açık) -->
    <Color x:Key="BackgroundDarkest">#0D0D1A</Color>
    <Color x:Key="BackgroundDark">#12122B</Color>
    <Color x:Key="BackgroundMedium">#1A1A3E</Color>
    <Color x:Key="BackgroundLight">#252550</Color>
    <Color x:Key="BackgroundCard">#1E1E40</Color>

    <!-- Vurgu renkleri -->
    <Color x:Key="AccentPrimary">#6C63FF</Color>
    <Color x:Key="AccentPrimaryHover">#7B73FF</Color>
    <Color x:Key="AccentPrimaryPressed">#5A52E0</Color>
    <Color x:Key="AccentSecondary">#00D9FF</Color>
    <Color x:Key="AccentGradientStart">#6C63FF</Color>
    <Color x:Key="AccentGradientEnd">#00D9FF</Color>

    <!-- Metin renkleri -->
    <Color x:Key="TextPrimary">#F0F0FF</Color>
    <Color x:Key="TextSecondary">#9494B8</Color>
    <Color x:Key="TextMuted">#5E5E7E</Color>
    <Color x:Key="TextOnAccent">#FFFFFF</Color>

    <!-- Durum renkleri -->
    <Color x:Key="StatusSuccess">#4ADE80</Color>
    <Color x:Key="StatusError">#F87171</Color>
    <Color x:Key="StatusWarning">#FBBF24</Color>

    <!-- Kenarlık ve ayırıcı -->
    <Color x:Key="BorderDefault">#2A2A55</Color>
    <Color x:Key="BorderFocused">#6C63FF</Color>
    <Color x:Key="DividerColor">#1F1F45</Color>

    <!-- ─── SolidColorBrush Tanımları ─── -->
    <SolidColorBrush x:Key="BrushBackgroundDarkest" Color="{StaticResource BackgroundDarkest}" />
    <SolidColorBrush x:Key="BrushBackgroundDark" Color="{StaticResource BackgroundDark}" />
    <SolidColorBrush x:Key="BrushBackgroundMedium" Color="{StaticResource BackgroundMedium}" />
    <SolidColorBrush x:Key="BrushBackgroundLight" Color="{StaticResource BackgroundLight}" />
    <SolidColorBrush x:Key="BrushBackgroundCard" Color="{StaticResource BackgroundCard}" />

    <SolidColorBrush x:Key="BrushAccentPrimary" Color="{StaticResource AccentPrimary}" />
    <SolidColorBrush x:Key="BrushAccentSecondary" Color="{StaticResource AccentSecondary}" />

    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="BrushTextOnAccent" Color="{StaticResource TextOnAccent}" />

    <SolidColorBrush x:Key="BrushStatusSuccess" Color="{StaticResource StatusSuccess}" />
    <SolidColorBrush x:Key="BrushStatusError" Color="{StaticResource StatusError}" />
    <SolidColorBrush x:Key="BrushStatusWarning" Color="{StaticResource StatusWarning}" />

    <SolidColorBrush x:Key="BrushBorderDefault" Color="{StaticResource BorderDefault}" />
    <SolidColorBrush x:Key="BrushBorderFocused" Color="{StaticResource BorderFocused}" />
    <SolidColorBrush x:Key="BrushDivider" Color="{StaticResource DividerColor}" />

    <!-- Gradient fırçaları -->
    <LinearGradientBrush x:Key="BrushAccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentGradientStart}" Offset="0" />
        <GradientStop Color="{StaticResource AccentGradientEnd}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BackgroundDarkest}" Offset="0" />
        <GradientStop Color="{StaticResource BackgroundDark}" Offset="1" />
    </LinearGradientBrush>

    <!-- ─── Tipografi ─── -->
    <FontFamily x:Key="FontPrimary">Segoe UI</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Code, Consolas</FontFamily>

    <system:Double x:Key="FontSizeXS"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>
    <system:Double x:Key="FontSizeS"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">12</system:Double>
    <system:Double x:Key="FontSizeMD"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">14</system:Double>
    <system:Double x:Key="FontSizeLG"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">16</system:Double>
    <system:Double x:Key="FontSizeXL"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">20</system:Double>
    <system:Double x:Key="FontSizeXXL"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">28</system:Double>
    <system:Double x:Key="FontSizeHero"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">36</system:Double>

    <!-- ─── Köşe Yuvarlaklıkları ─── -->
    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">16</CornerRadius>
    <CornerRadius x:Key="RadiusRound">999</CornerRadius>

    <!-- ─── Gölge Efektleri ─── -->
    <DropShadowEffect x:Key="ShadowSmall" BlurRadius="8" ShadowDepth="2"
                      Color="#000000" Opacity="0.3" Direction="270" />
    <DropShadowEffect x:Key="ShadowMedium" BlurRadius="16" ShadowDepth="4"
                      Color="#000000" Opacity="0.4" Direction="270" />
    <DropShadowEffect x:Key="ShadowLarge" BlurRadius="32" ShadowDepth="8"
                      Color="#000000" Opacity="0.5" Direction="270" />
    <DropShadowEffect x:Key="ShadowGlow" BlurRadius="20" ShadowDepth="0"
                      Color="{StaticResource AccentPrimary}" Opacity="0.3" />

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- BUTTON STİLLERİ                                     -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- Ana Aksiyon Butonu (Uygulama Ekle, Kaydet vb.) -->
    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushAccentPrimary}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextOnAccent}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentPrimaryHover}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentPrimaryPressed}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- İkincil Buton (İptal, Geri vb.) -->
    <Style x:Key="BtnSecondary" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background"
                                    Value="{StaticResource BrushBackgroundLight}" />
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background"
                                    Value="{StaticResource BrushBackgroundMedium}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tehlike Butonu (Sil, Kaldır vb.) -->
    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource StatusError}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- İkon Buton (yuvarlak, sadece ikon) -->
    <Style x:Key="BtnIcon" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusRound}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background"
                                    Value="{StaticResource BrushBackgroundLight}" />
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TEXT INPUT STİLLERİ                                 -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style x:Key="InputText" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundDark}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushAccentPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush"
                                    Value="{StaticResource BrushBorderFocused}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputPassword" TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundDark}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushAccentPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeLG}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush"
                                    Value="{StaticResource BrushBorderFocused}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TOGGLE SWITCH STİLİ                                 -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="ToggleTrack"
                                Background="{StaticResource BrushBackgroundLight}"
                                CornerRadius="12"
                                Width="44" Height="24" />
                        <Border x:Name="ToggleThumb"
                                Background="{StaticResource BrushTextSecondary}"
                                CornerRadius="10"
                                Width="20" Height="20"
                                HorizontalAlignment="Left"
                                Margin="2,0,0,0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ToggleTrack" Property="Background"
                                    Value="{StaticResource BrushAccentPrimary}" />
                            <Setter TargetName="ToggleThumb" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource TextOnAccent}" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="ToggleThumb" Property="Margin" Value="0,0,2,0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- KART / PANEL STİLLERİ                               -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundCard}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect" Value="{StaticResource ShadowSmall}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SCROLLBAR STİLİ                                     -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6" />
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="6" />
                <Setter Property="Width" Value="Auto" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TOOLTIP STİLİ                                       -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundLight}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeS}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

</ResourceDictionary>
