<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- WinAppLock Karanlık Tema Kaynak Sözlüğü             -->
    <!-- Tüm renk, font, boyut ve stil tanımları burada.     -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- ─── Renk Paleti ─── -->
    <!-- ─── Renk Paleti ─── -->
    <!-- Ana arkaplan tonları (Discord Minimalist) -->
    <Color x:Key="BackgroundDarkest">#2B2D31</Color>     <!-- TitleBar / Sidebar (Secondary) -->
    <Color x:Key="BackgroundDark">#313338</Color>        <!-- Ana İçerik / Dashboard -->
    <Color x:Key="BackgroundMedium">#1E1F22</Color>      <!-- Koyu Kartlar / Inner Panels -->
    <Color x:Key="BackgroundLight">#383A40</Color>       <!-- Hover Zeminleri / Açık Butonlar -->
    <Color x:Key="BackgroundCard">#2B2D31</Color>        <!-- Kart Zeminleri (Main Content Card) -->

    <!-- Vurgu renkleri (Blurple tabanlı) -->
    <Color x:Key="AccentPrimary">#5865F2</Color>         <!-- Blurple (Ana Aksan) -->
    <Color x:Key="AccentPrimaryHover">#4752C4</Color>    <!-- Blurple Hover -->
    <Color x:Key="AccentPrimaryPressed">#3C45A5</Color>  <!-- Blurple Pressed -->
    <Color x:Key="AccentSecondary">#23A559</Color>       <!-- İkincil Vurgu (Discord Green) -->
    <Color x:Key="AccentGradientStart">#5865F2</Color>
    <Color x:Key="AccentGradientEnd">#4752C4</Color>

    <!-- Metin renkleri -->
    <Color x:Key="TextPrimary">#DBDEE1</Color>           <!-- Açık Gri Ana Metin -->
    <Color x:Key="TextSecondary">#B5BAC1</Color>         <!-- İkincil Metin -->
    <Color x:Key="TextMuted">#949BA4</Color>             <!-- Sönük / İptal Metinler -->
    <Color x:Key="TextOnAccent">#FFFFFF</Color>          <!-- Blurple üstü tam beyaz -->

    <!-- Durum renkleri -->
    <Color x:Key="StatusSuccess">#23A559</Color>         <!-- Discord Yeşili -->
    <Color x:Key="StatusError">#DA373C</Color>           <!-- Discord Kırmızısı -->
    <Color x:Key="StatusWarning">#FEE75C</Color>         <!-- Discord Sarısı -->

    <!-- Kenarlık ve ayırıcı -->
    <Color x:Key="BorderDefault">#1E1F22</Color>         <!-- Silik iç içe geçiş sınırları -->
    <Color x:Key="BorderFocused">#5865F2</Color>         <!-- Seçili durum Blurple sınır -->
    <Color x:Key="DividerColor">#1E1F22</Color>

    <!-- ─── SolidColorBrush Tanımları ─── -->
    <SolidColorBrush x:Key="BrushBackgroundDarkest" Color="{StaticResource BackgroundDarkest}" />
    <SolidColorBrush x:Key="BrushBackgroundDark" Color="{StaticResource BackgroundDark}" />
    <SolidColorBrush x:Key="BrushBackgroundMedium" Color="{StaticResource BackgroundMedium}" />
    <SolidColorBrush x:Key="BrushBackgroundLight" Color="{StaticResource BackgroundLight}" />
    <SolidColorBrush x:Key="BrushBackgroundCard" Color="{StaticResource BackgroundCard}" />

    <SolidColorBrush x:Key="BrushAccentPrimary" Color="{StaticResource AccentPrimary}" />
    <SolidColorBrush x:Key="BrushAccentSecondary" Color="{StaticResource AccentSecondary}" />

    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="BrushTextOnAccent" Color="{StaticResource TextOnAccent}" />

    <SolidColorBrush x:Key="BrushStatusSuccess" Color="{StaticResource StatusSuccess}" />
    <SolidColorBrush x:Key="BrushStatusError" Color="{StaticResource StatusError}" />
    <SolidColorBrush x:Key="BrushStatusWarning" Color="{StaticResource StatusWarning}" />

    <SolidColorBrush x:Key="BrushBorderDefault" Color="{StaticResource BorderDefault}" />
    <SolidColorBrush x:Key="BrushBorderFocused" Color="{StaticResource BorderFocused}" />
    <SolidColorBrush x:Key="BrushDivider" Color="{StaticResource DividerColor}" />
    <SolidColorBrush x:Key="BrushCardBorder" Color="{StaticResource BorderDefault}" />

    <!-- Gradient fırçaları -->
    <LinearGradientBrush x:Key="BrushAccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentGradientStart}" Offset="0" />
        <GradientStop Color="{StaticResource AccentGradientEnd}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BackgroundDarkest}" Offset="0" />
        <GradientStop Color="{StaticResource BackgroundDark}" Offset="1" />
    </LinearGradientBrush>

    <!-- ─── Tipografi ─── -->
    <FontFamily x:Key="FontPrimary">Segoe UI</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Code, Consolas</FontFamily>

    <system:Double x:Key="FontSizeXS"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>
    <system:Double x:Key="FontSizeS"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">12</system:Double>
    <system:Double x:Key="FontSizeMD"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">14</system:Double>
    <system:Double x:Key="FontSizeLG"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">16</system:Double>
    <system:Double x:Key="FontSizeXL"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">20</system:Double>
    <system:Double x:Key="FontSizeXXL"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">28</system:Double>
    <system:Double x:Key="FontSizeHero"
                   xmlns:system="clr-namespace:System;assembly=mscorlib">36</system:Double>

    <!-- ─── Köşe Yuvarlaklıkları ─── -->
    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
    <CornerRadius x:Key="RadiusXLarge">16</CornerRadius>
    <CornerRadius x:Key="RadiusRound">999</CornerRadius>

    <!-- ─── Gölge Efektleri ─── -->
    <DropShadowEffect x:Key="ShadowSmall" BlurRadius="8" ShadowDepth="2"
                      Color="#000000" Opacity="0.3" Direction="270" />
    <DropShadowEffect x:Key="ShadowMedium" BlurRadius="16" ShadowDepth="4"
                      Color="#000000" Opacity="0.4" Direction="270" />
    <DropShadowEffect x:Key="ShadowLarge" BlurRadius="32" ShadowDepth="8"
                      Color="#000000" Opacity="0.5" Direction="270" />
    <DropShadowEffect x:Key="ShadowGlow" BlurRadius="20" ShadowDepth="0"
                      Color="{StaticResource AccentPrimary}" Opacity="0.3" />

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- BUTTON STİLLERİ                                     -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- Ana Aksiyon Butonu (Uygulama Ekle, Kaydet vb.) -->
    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushAccentPrimary}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextOnAccent}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentPrimaryHover}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource AccentPrimaryPressed}" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- İkincil Buton (İptal, Geri vb.) -->
    <Style x:Key="BtnSecondary" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background"
                                    Value="{StaticResource BrushBackgroundLight}" />
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background"
                                    Value="{StaticResource BrushBackgroundMedium}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tehlike Butonu (Sil, Kaldır vb.) -->
    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource StatusError}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- İkon Buton (yuvarlak, sadece ikon) -->
    <Style x:Key="BtnIcon" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusRound}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background"
                                    Value="{StaticResource BrushBackgroundLight}" />
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Hayalet Buton (Sadece metin, hoverda hafif arka plan) -->
    <Style x:Key="BtnGhost" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeS}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BtnBorder" Property="Background"
                                    Value="{StaticResource BrushBackgroundLight}" />
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.7" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TEXT INPUT STİLLERİ                                 -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style x:Key="InputText" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundDark}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushAccentPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush"
                                    Value="{StaticResource BrushBorderFocused}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputPassword" TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundDark}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushAccentPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeLG}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="InputBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="InputBorder" Property="BorderBrush"
                                    Value="{StaticResource BrushBorderFocused}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- DROPDOWN (COMBOBOX) STİLLERİ                        -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Margin="4,2">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource BrushBackgroundLight}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource BrushAccentPrimary}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundDark}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Foreground="{TemplateBinding Foreground}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="{StaticResource RadiusMedium}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <Path x:Name="Arrow"
                                                  Grid.Column="1"
                                                  Fill="{TemplateBinding Foreground}"
                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Opacity="0.6" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Arrow" Property="Opacity" Value="1" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left" />

                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">
                            <Border x:Name="DropDownBorder"
                                    Background="{StaticResource BrushBackgroundDarkest}"
                                    BorderBrush="{StaticResource BrushBorderDefault}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Margin="0,4,0,0">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderFocused}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderFocused}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TOGGLE SWITCH STİLİ                                 -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid Background="Transparent">
                        <Border x:Name="ToggleTrack"
                                Background="{StaticResource BrushBackgroundLight}"
                                CornerRadius="12"
                                Width="44" Height="24" />
                        
                        <Border x:Name="ToggleThumb"
                                Background="{StaticResource BrushTextSecondary}"
                                CornerRadius="10"
                                Width="20" Height="20"
                                HorizontalAlignment="Left"
                                Margin="2,0,0,0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ThumbTranslate" X="0" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" />
                            </Border.Effect>
                        </Border>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="20" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ToggleTrack"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource StatusSuccess}" Duration="0:0:0.2" />
                                        <ColorAnimation Storyboard.TargetName="ToggleThumb"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="White" Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unchecked">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="ToggleTrack"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource BackgroundLight}" Duration="0:0:0.2" />
                                        <ColorAnimation Storyboard.TargetName="ToggleThumb"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource TextSecondary}" Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- KART / PANEL STİLLERİ                               -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundCard}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect" Value="{StaticResource ShadowSmall}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SCROLLBAR STİLİ                                     -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6" />
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="6" />
                <Setter Property="Width" Value="Auto" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- TOOLTIP STİLİ                                       -->
    <!-- ═══════════════════════════════════════════════════ -->

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource BrushBackgroundLight}" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeS}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <!-- ─── Navigasyon Stilleri ─── -->
    <Style x:Key="NavTabButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="2,0,0,0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                <Setter Property="Background" Value="{StaticResource BrushBackgroundLight}" />
            </Trigger>
            <Trigger Property="Tag" Value="Active">
                <Setter Property="BorderBrush" Value="{StaticResource BrushAccentPrimary}" />
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
                <Setter Property="Background" Value="{StaticResource BrushBackgroundMedium}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LabelPrimary" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMD}" />
    </Style>

</ResourceDictionary>
