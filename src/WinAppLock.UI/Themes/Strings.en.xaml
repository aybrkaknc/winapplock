<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xml:space="preserve">

    <!-- Global -->
    <sys:String x:Key="Str_AppTitle">WinAppLock</sys:String>
    <sys:String x:Key="Str_BtnBack">← Back</sys:String>
    <sys:String x:Key="Str_BtnSkip">Skip</sys:String>
    <sys:String x:Key="Str_BtnNext">Next →</sys:String>
    <sys:String x:Key="Str_BtnComplete">Complete ✓</sys:String>
    
    <!-- SetupWizard -->
    <sys:String x:Key="Str_SetupTitle">WinAppLock Setup</sys:String>
    <sys:String x:Key="Str_SetupWelcomeTitle">Welcome to WinAppLock!</sys:String>
    <sys:String x:Key="Str_SetupWelcomeDesc">Securely protect your applications.&#x0a;Finishing the setup will only take a few seconds.</sys:String>
    <sys:String x:Key="Str_Language">Language / Dil</sys:String>
    <sys:String x:Key="Str_LangTR">  Türkçe</sys:String>
    <sys:String x:Key="Str_LangEN">  English</sys:String>

    <sys:String x:Key="Str_LockMethod">Lock Method</sys:String>
    <sys:String x:Key="Str_LockMethodDesc">Which method would you like to use to unlock your apps?</sys:String>
    <sys:String x:Key="Str_PinCode">🔢  PIN Code</sys:String>
    <sys:String x:Key="Str_PinCodeDesc">4-8 digit numeric code. Fast and practical.</sys:String>
    <sys:String x:Key="Str_Password">🔑  Alphanumeric Password</sys:String>
    <sys:String x:Key="Str_PasswordDesc">Letters, numbers and special characters. More secure.</sys:String>
    <sys:String x:Key="Str_PinLength">PIN Length</sys:String>

    <sys:String x:Key="Str_MasterSetTitle">Set Master PIN/Password</sys:String>
    <sys:String x:Key="Str_MasterSetDesc">You will use this code to unlock every protected application.</sys:String>
    <sys:String x:Key="Str_SetupPasswordTitle">Password</sys:String>
    <sys:String x:Key="Str_SetupPasswordConfirm">Confirm Password</sys:String>

    <sys:String x:Key="Str_RecoveryKeyTitle">🔑 Your Recovery Key</sys:String>
    <sys:String x:Key="Str_RecoveryKeyDesc">If you forget your password, you can reset it with this key.&#x0a;Save this key somewhere secure! It won't be shown again.</sys:String>
    <sys:String x:Key="Str_BtnCopy">📋  Copy to Clipboard</sys:String>

    <sys:String x:Key="Str_SecurityQuestionTitle">Security Question (Optional)</sys:String>
    <sys:String x:Key="Str_SecurityQuestionDesc">An extra layer of security for password recovery.&#x0a;You can skip this step if you want.</sys:String>
    <sys:String x:Key="Str_SecurityQuestion">Security Question</sys:String>
    <sys:String x:Key="Str_SecurityAnswer">Answer</sys:String>

    <!-- MainWindow -->
    <sys:String x:Key="Str_Dashboard">Dashboard</sys:String>
    <sys:String x:Key="Str_Settings">Settings</sys:String>


    <!-- Dashboard -->
    <sys:String x:Key="Str_LockedApps">Locked Apps</sys:String>
    <sys:String x:Key="Str_AppCount">apps protected</sys:String>
    <sys:String x:Key="Str_BtnAddApp">＋  Add App</sys:String>
    
    <sys:String x:Key="Str_EmptyStateTitle">No locked apps yet</sys:String>
    <sys:String x:Key="Str_EmptyStateDesc">To protect an application, click the 'Add App' button above&#x0a;or drag and drop an .exe file here.</sys:String>
    <sys:String x:Key="Str_BtnEmptyAdd">＋  Add First App</sys:String>

    <!-- SettingsView -->
    <sys:String x:Key="Str_SettingsTitle">⚙️  Settings</sys:String>
    <sys:String x:Key="Str_Security">SECURITY</sys:String>
    
    <sys:String x:Key="Str_ChangePasswordTitle">Change Password</sys:String>
    <sys:String x:Key="Str_ChangePasswordDesc">Change your master password or PIN</sys:String>
    <sys:String x:Key="Str_BtnChange">Change</sys:String>
    
    <sys:String x:Key="Str_MaxAttemptsTitle">Failed Attempt Limit</sys:String>
    <sys:String x:Key="Str_MaxAttemptsDesc">Apply temporary block when limit is reached</sys:String>
    <sys:String x:Key="Str_LimitCount"> attempts</sys:String>
    
    <sys:String x:Key="Str_CooldownTitle">Cooldown Time</sys:String>
    <sys:String x:Key="Str_CooldownDesc">How many seconds to wait after limit is reached</sys:String>
    <sys:String x:Key="Str_Seconds"> sec</sys:String>
    <sys:String x:Key="Str_Minute"> Minute</sys:String>
    <sys:String x:Key="Str_Minutes"> Minutes</sys:String>
    <sys:String x:Key="Str_Attempts"> Attempts</sys:String>
    <sys:String x:Key="Str_AlwaysPrompt">Always Prompt</sys:String>

    <sys:String x:Key="Str_UiTimeoutTitle">UI Timeout</sys:String>
    <sys:String x:Key="Str_UiTimeoutDesc">Ask for password again when idle</sys:String>

    <sys:String x:Key="Str_AutoRelockTitle">Auto Relock Duration</sys:String>
    <sys:String x:Key="Str_AutoRelockDesc">Suspend open apps automatically after a certain time</sys:String>
    <sys:String x:Key="Str_RelockDisabled">Disabled</sys:String>
    <sys:String x:Key="Str_RelockMinutes">{0} Minutes</sys:String>
    <sys:String x:Key="Str_RelockHour">1 Hour</sys:String>

    <sys:String x:Key="Str_General">GENERAL</sys:String>
    <sys:String x:Key="Str_SoundEffectsTitle">Sound Effects</sys:String>
    <sys:String x:Key="Str_SoundEffectsDesc">Correct/Wrong input sound</sys:String>

    <sys:String x:Key="Str_AutostartTitle">Start with Windows</sys:String>
    <sys:String x:Key="Str_AutostartDesc">Start automatically when computer boots</sys:String>
    
    <sys:String x:Key="Str_LanguageDesc">Change interface language</sys:String>

    <sys:String x:Key="Str_About">ABOUT</sys:String>
    <sys:String x:Key="Str_BtnSaveSettings">💾  Save Settings</sys:String>

    <!-- LockOverlay -->
    <sys:String x:Key="Str_LockedBy">is locked by</sys:String>
    <sys:String x:Key="Str_EnterPin">This app is locked. Enter your PIN.</sys:String>
    <sys:String x:Key="Str_EnterPassword">This app is locked. Enter your password.</sys:String>
    <sys:String x:Key="Str_Unlock">Unlock</sys:String>
    <sys:String x:Key="Str_WrongPassword">Wrong password!</sys:String>
    <sys:String x:Key="Str_TooManyAttempts">Too many failed attempts!</sys:String>
    <sys:String x:Key="Str_WaitSeconds">Please wait {0} seconds.</sys:String>
    <sys:String x:Key="Str_AttemptsRemaining">{0} attempts remaining.</sys:String>
    <sys:String x:Key="Str_TryAgain">You can try again.</sys:String>

    <!-- MainWindow Code-Behind -->
    <sys:String x:Key="Str_DialogSelectApp">Select an application to lock</sys:String>
    <sys:String x:Key="Str_DialogExeFilter">Executable Files (*.exe)|*.exe</sys:String>
    <sys:String x:Key="Str_AlreadyLocked">This application is already locked!</sys:String>
    <sys:String x:Key="Str_AddError">Error adding application:</sys:String>
    <sys:String x:Key="Str_ToggleDisable">Disable lock</sys:String>
    <sys:String x:Key="Str_ToggleEnable">Enable lock</sys:String>
    <sys:String x:Key="Str_RemoveLock">Remove lock</sys:String>
    <sys:String x:Key="Str_ConfirmRemove">Are you sure you want to remove the lock on "{0}"?</sys:String>
    <sys:String x:Key="Str_ConfirmRemoveTitle">Remove Lock</sys:String>
    <sys:String x:Key="Str_AllLocked">All locked applications have been locked!</sys:String>

    <!-- SettingsView Code-Behind -->
    <sys:String x:Key="Str_Saved">✓  Saved!</sys:String>
    <sys:String x:Key="Str_ChangePasswordSoon">Password change feature will be added soon.</sys:String>

    <!-- SetupWizard Code-Behind -->
    <sys:String x:Key="Str_Copied">✓  Copied!</sys:String>
    <sys:String x:Key="Str_PasswordEmpty">Password cannot be empty.</sys:String>
    <sys:String x:Key="Str_PasswordMismatch">Passwords do not match.</sys:String>
    <sys:String x:Key="Str_MasterPinSet">Set Master PIN ({0} Digits)</sys:String>
    <sys:String x:Key="Str_MasterPinSetDesc">You will use this PIN to unlock every protected application.</sys:String>
    <sys:String x:Key="Str_MasterPasswordSet">Set Master Password</sys:String>
    <sys:String x:Key="Str_MasterPasswordSetDesc">You will use this password to unlock every protected application.</sys:String>
    <sys:String x:Key="Str_StepFormat">Step {0}/{1} — {2}</sys:String>
    <sys:String x:Key="Str_Step1Name">Welcome</sys:String>
    <sys:String x:Key="Str_Step2Name">Lock Method</sys:String>
    <sys:String x:Key="Str_Step3Name">Set Password</sys:String>
    <sys:String x:Key="Str_Step4Name">Recovery Key</sys:String>
    <sys:String x:Key="Str_Step5Name">Security Question</sys:String>

    <!-- App.xaml.cs -->
    <sys:String x:Key="Str_AlreadyRunning">WinAppLock is already running!</sys:String>
    <sys:String x:Key="Str_UnexpectedError">An unexpected error occurred:</sys:String>
    <sys:String x:Key="Str_TrayAllLocked">All apps locked! 🔐</sys:String>
    <sys:String x:Key="Str_UnknownApp">Unknown Application</sys:String>

    <!-- LockOverlay XAML -->
    <sys:String x:Key="Str_OverlayTitle">WinAppLock - Authentication</sys:String>
    <sys:String x:Key="Str_DefaultPrompt">This app is locked. Enter your credentials to continue.</sys:String>

    <!-- MainWindow Tooltips -->
    <sys:String x:Key="Str_ToolTipMinimize">Minimize</sys:String>
    <sys:String x:Key="Str_ToolTipClose">Minimize to System Tray</sys:String>
    <sys:String x:Key="Str_ToolTipAddApp">Lock a new application</sys:String>

    <!-- TrayIconService -->
    <sys:String x:Key="Str_TrayTooltip">WinAppLock — Apps are protected</sys:String>
    <sys:String x:Key="Str_TrayOpen">Open WinAppLock</sys:String>
    <sys:String x:Key="Str_TrayLockAll">🔐 Lock All</sys:String>
    <sys:String x:Key="Str_TrayExit">Exit</sys:String>

    <!-- ChangePasswordWindow -->
    <sys:String x:Key="Str_CP_Title">Change Password</sys:String>
    <sys:String x:Key="Str_CP_Step1">Authentication</sys:String>
    <sys:String x:Key="Str_CP_VerifyDesc">Verify your identity by entering your current password or PIN to continue.</sys:String>
    <sys:String x:Key="Str_CP_EnterCurrentPin">Enter Current PIN</sys:String>
    <sys:String x:Key="Str_CP_EnterCurrentPassword">Enter Current Password</sys:String>
    <sys:String x:Key="Str_CP_Verify">Verify</sys:String>
    <sys:String x:Key="Str_CP_Incorrect">Incorrect entry! Attempts remaining: {0}</sys:String>
    <sys:String x:Key="Str_CP_LockedOut">Too many failed attempts!\nOperation blocked for security.</sys:String>
    <sys:String x:Key="Str_CP_NewRecoveryKeyDesc">Your old recovery key is revoked.&#x0a;Save this new key for your security!</sys:String>

</ResourceDictionary>
