    <sys:String x:Key="Str_SettingsTitle">⚙️  Ayarlar</sys:String>
    <sys:String x:Key="Str_Security">GÜVENLİK</sys:String>
    
    <sys:String x:Key="Str_ChangePasswordTitle">Şifre Değiştir</sys:String>
    <sys:String x:Key="Str_ChangePasswordDesc">Master şifreni veya PIN'ini değiştir</sys:String>
    <sys:String x:Key="Str_BtnChange">Değiştir</sys:String>
    
    <sys:String x:Key="Str_MaxAttemptsTitle">Hatalı Giriş Limiti</sys:String>
    <sys:String x:Key="Str_MaxAttemptsDesc">Limiti aşınca geçici bloklama uygula</sys:String>
    <sys:String x:Key="Str_LimitCount"> deneme</sys:String>
    
    <sys:String x:Key="Str_CooldownTitle">Bekleme Süresi</sys:String>
    <sys:String x:Key="Str_CooldownDesc">Limit aşıldığında kaç saniye beklenecek</sys:String>
    <sys:String x:Key="Str_Seconds"> sn</sys:String>

    <sys:String x:Key="Str_UiTimeoutTitle">UI Zaman Aşımı</sys:String>
    <sys:String x:Key="Str_UiTimeoutDesc">İşlem yapılmadığında tekrar şifre sor</sys:String>

    <sys:String x:Key="Str_General">GENEL</sys:String>
    <sys:String x:Key="Str_SoundEffectsTitle">Ses Efektleri</sys:String>
    <sys:String x:Key="Str_SoundEffectsDesc">Doğru/yanlış giriş sesi</sys:String>

    <sys:String x:Key="Str_AutostartTitle">Windows Başlangıcında Çalış</sys:String>
    <sys:String x:Key="Str_AutostartDesc">Bilgisayar açıldığında otomatik başlat</sys:String>
    
    <sys:String x:Key="Str_LanguageDesc">Arayüz dilini değiştir</sys:String>

    <sys:String x:Key="Str_About">HAKKINDA</sys:String>
    <sys:String x:Key="Str_BtnSaveSettings">💾  Ayarları Kaydet</sys:String>

    <!-- LockOverlay -->
    <sys:String x:Key="Str_LockedBy">tarafından kilitlendi.</sys:String>
    <sys:String x:Key="Str_EnterPin">PIN Kodunu Girin</sys:String>
    <sys:String x:Key="Str_EnterPassword">Şifrenizi Girin</sys:String>
    <sys:String x:Key="Str_Unlock">Kilidi Aç</sys:String>

</ResourceDictionary>
