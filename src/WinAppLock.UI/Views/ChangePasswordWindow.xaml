<Window x:Class="WinAppLock.UI.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str_CP_Title}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Numpad Butonları için Ortak Stil -->
        <Style x:Key="NumpadBtn" TargetType="Button" BasedOn="{StaticResource BtnSecondary}">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>
    </Window.Resources>

    <!-- ─── Tam Ekran Karartma Arkaplanı ─── -->
    <Grid x:Name="OverlayBackground">
        <Grid.Background>
            <SolidColorBrush Color="#000000" Opacity="0.90" />
        </Grid.Background>

        <!-- Merkezi Şifre Değiştirme Kartı -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="520"
                Background="{StaticResource BrushBackgroundDarkest}"
                CornerRadius="{StaticResource RadiusLarge}"
                BorderBrush="{StaticResource BrushBorderDefault}"
                BorderThickness="1"
                Effect="{StaticResource ShadowMedium}"
                ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ─── Window Header ─── -->
            <Border Grid.Row="0" Background="{StaticResource BrushBackgroundDark}"
                    Padding="24,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Str_CP_Title}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="WizardStepText" Text="Adım 1/4 — Doğrulama"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeS}"
                               Margin="0,4,0,0" />
                    <Grid Margin="0,12,0,0" Height="4">
                        <Border Background="{StaticResource BrushBackgroundLight}" CornerRadius="2" />
                        <Border x:Name="WizardProgressBar"
                                Background="{StaticResource BrushAccentGradient}"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                Width="118" /> <!-- 472 * 1/4 = 118 -->
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── Content ─── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="32,24,32,24">

                <!-- ═══ ADIM 1: Doğrulama (Auth) ═══ -->
                <StackPanel x:Name="Step1Auth" Visibility="Visible">
                    <!-- Başlık & İkon -->
                    <TextBlock Text="🛡️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16" />
                    <TextBlock Text="{DynamicResource Str_CP_Step1}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXXL}"
                               FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="{DynamicResource Str_CP_VerifyDesc}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               TextAlignment="Center" Margin="0,8,0,24" TextWrapping="Wrap" />

                    <!-- Alfanümerik Şifre Alanı -->
                    <StackPanel x:Name="AuthPasswordArea" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource Str_CP_EnterCurrentPassword}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="InputCurrentPassword"
                                     Style="{StaticResource InputPassword}"
                                     Margin="0,0,0,12" />
                    </StackPanel>

                    <!-- PIN Giriş ve Numpad Alanı -->
                    <StackPanel x:Name="AuthPinArea" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource Str_CP_EnterCurrentPin}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4"
                                   HorizontalAlignment="Center"/>
                        
                        <StackPanel x:Name="PinDotsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16" />

                        <!-- Numpad -->
                        <Grid HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />
                            <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />
                            <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />

                            <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />
                            <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />
                            <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />

                            <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />
                            <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />
                            <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />

                            <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource NumpadBtn}" Click="Numpad_Click" />
                            <Button Grid.Row="3" Grid.Column="2" Content="⌫" Style="{StaticResource NumpadBtn}" Click="NumpadBackspace_Click" Foreground="{StaticResource BrushStatusError}" />
                        </Grid>
                    </StackPanel>

                    <!-- Hata Mesajı -->
                    <TextBlock x:Name="AuthErrorText" Text=""
                               Foreground="{StaticResource BrushStatusError}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               HorizontalAlignment="Center" Margin="0,16,0,0" />
                </StackPanel>

                <!-- ═══ ADIM 2: Doğrulama Yöntemi ═══ -->
                <StackPanel x:Name="Step2Method" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str_LockMethod}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="{DynamicResource Str_LockMethodDesc}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               Margin="0,0,0,24"  />

                    <!-- PIN Seçeneği -->
                    <Border x:Name="CardAuthPin" Style="{StaticResource CardPanel}"
                            Margin="0,0,0,12" Cursor="Hand"
                            MouseLeftButtonDown="CardAuthPin_Click">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_PinCode}"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeLG}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource Str_PinCodeDesc}"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Şifre Seçeneği -->
                    <Border x:Name="CardAuthPassword" Style="{StaticResource CardPanel}"
                            Cursor="Hand"
                            MouseLeftButtonDown="CardAuthPassword_Click">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_Password}"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeLG}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource Str_PasswordDesc}"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>


                <!-- ═══ ADIM 3: Şifre Yenileme ═══ -->
                <StackPanel x:Name="Step3SetPassword" Visibility="Collapsed">
                    <TextBlock x:Name="Step3Title" Text="{DynamicResource Str_MasterSetTitle}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock x:Name="Step3Description"
                               Text="{DynamicResource Str_MasterSetDesc}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               Margin="0,0,0,24" />

                    <!-- KLASİK ŞİFRE ALANI -->
                    <StackPanel x:Name="SetupPasswordArea" Visibility="Visible">
                        <TextBlock Text="{DynamicResource Str_SetupPasswordTitle}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="SetupPasswordBox1" Style="{StaticResource InputPassword}" Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Str_SetupPasswordConfirm}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="SetupPasswordBox2" Style="{StaticResource InputPassword}" Margin="0,0,0,8" />
                    </StackPanel>

                    <!-- DOKUNMATİK PIN (NUMPAD) ALANI -->
                    <StackPanel x:Name="SetupPinArea" Visibility="Collapsed">
                        <TextBlock Text="{DynamicResource Str_SetupPasswordTitle}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4"
                                   HorizontalAlignment="Center" />
                        <StackPanel x:Name="SetupPin1DotsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Str_SetupPasswordConfirm}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4"
                                   HorizontalAlignment="Center" />
                        <StackPanel x:Name="SetupPin2DotsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16" />

                        <!-- Numpad -->
                        <Grid HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Content="1" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />
                            <Button Grid.Row="0" Grid.Column="1" Content="2" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />
                            <Button Grid.Row="0" Grid.Column="2" Content="3" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />

                            <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />
                            <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />
                            <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />

                            <Button Grid.Row="2" Grid.Column="0" Content="7" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />
                            <Button Grid.Row="2" Grid.Column="1" Content="8" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />
                            <Button Grid.Row="2" Grid.Column="2" Content="9" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />

                            <Button Grid.Row="3" Grid.Column="1" Content="0" Style="{StaticResource NumpadBtn}" Click="SetupNumpad_Click" />
                            <Button Grid.Row="3" Grid.Column="2" Content="⌫" Style="{StaticResource NumpadBtn}" Click="SetupNumpadBackspace_Click" Foreground="{StaticResource BrushStatusError}" />
                        </Grid>
                    </StackPanel>

                    <TextBlock x:Name="SetPasswordError" Text=""
                               Foreground="{StaticResource BrushStatusError}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeS}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />
                </StackPanel>

                <!-- ═══ ADIM 4: Kurtarma Anahtarı ═══ -->
                <StackPanel x:Name="Step4Recovery" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str_RecoveryKeyTitle}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="{DynamicResource Str_CP_NewRecoveryKeyDesc}"
                               Foreground="{StaticResource BrushStatusWarning}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               TextWrapping="Wrap" LineHeight="22"
                               Margin="0,0,0,20" />

                    <Border Background="{StaticResource BrushBackgroundDark}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="20,16" Margin="0,0,0,16"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="RecoveryKeyDisplay"
                                   Text="WAL-XXXX-XXXX-XXXX-XXXX"
                                   Foreground="{StaticResource BrushAccentSecondary}"
                                   FontFamily="{StaticResource FontMono}"
                                   FontSize="{StaticResource FontSizeXL}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Button x:Name="BtnCopyRecoveryKey"
                            Content="{DynamicResource Str_BtnCopy}"
                            Style="{StaticResource BtnSecondary}"
                            HorizontalAlignment="Center"
                            Click="BtnCopyRecoveryKey_Click" />
                </StackPanel>

                </Grid>
            </ScrollViewer>

            <!-- ─── Window Footer ─── -->
            <Border Grid.Row="2" Background="{StaticResource BrushBackgroundDark}" Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Kapat Butonu -->
                    <Button x:Name="BtnCancel" Grid.Column="0"
                            Content="Kapat"
                            Style="{StaticResource BtnSecondary}"
                            HorizontalAlignment="Left"
                            Click="BtnCancel_Click" />

                    <!-- Geri Butonu -->
                    <Button x:Name="BtnBack" Grid.Column="1"
                            Content="{DynamicResource Str_BtnBack}"
                            Style="{StaticResource BtnSecondary}"
                            HorizontalAlignment="Right" Margin="0,0,8,0"
                            Click="BtnBack_Click"
                            Visibility="Collapsed" />

                    <!-- İleri / Tamamla Butonu -->
                    <Button x:Name="BtnNext" Grid.Column="2"
                            Content="{DynamicResource Str_CP_Verify}"
                            Style="{StaticResource BtnPrimary}"
                            HorizontalAlignment="Right"
                            Click="BtnNext_Click" />
                </Grid>
            </Border>
        </Grid>
        </Border>
    </Grid>
</Window>
