<Window x:Class="WinAppLock.UI.Views.LockOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinAppLock - Doğrulama"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <!-- 
    ═══════════════════════════════════════════════════
    LockOverlay: Tüm ekranı kaplayan şifre giriş ekranı.
    Kilitli uygulama algılandığında Service tarafından tetiklenir.
    
    Yapı:
    - Yarı-saydam koyu arkaplan (karartma efekti)
    - Ortada şifre giriş kartı
    - Fade-in + scale animasyonu (~200ms)
    ═══════════════════════════════════════════════════
    -->

    <Window.Resources>
        <!-- Giriş animasyonu -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetName="OverlayBackground"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2"
                             EasingFunction="{StaticResource {x:Static SystemParameters.MenuAnimationKey}}" />
            <DoubleAnimation Storyboard.TargetName="AuthCardScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.9" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AuthCardScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.9" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Hata titreşim animasyonu -->
        <Storyboard x:Key="ShakeAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AuthCardTranslate"
                                            Storyboard.TargetProperty="X">
                <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="10" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="-10" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="8" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="-8" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="4" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Başarı animasyonu (yeşil parlama) -->
        <Storyboard x:Key="SuccessAnimation">
            <ColorAnimation Storyboard.TargetName="AuthCardBorder"
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="{StaticResource StatusSuccess}"
                            Duration="0:0:0.3" />
            <DoubleAnimation Storyboard.TargetName="OverlayBackground"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.4"
                             BeginTime="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- ─── Tam Ekran Karartma Arkaplanı ─── -->
    <Grid x:Name="OverlayBackground" Opacity="0">
        <Grid.Background>
            <SolidColorBrush Color="#000000" Opacity="0.85" />
        </Grid.Background>

        <!-- ─── Merkez Auth Kartı ─── -->
        <Border x:Name="AuthCardBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="380"
                Background="{StaticResource BrushBackgroundCard}"
                BorderBrush="{StaticResource BrushBorderDefault}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusXLarge}"
                Padding="32"
                Effect="{StaticResource ShadowLarge}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="AuthCardScale" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="AuthCardTranslate" X="0" />
                </TransformGroup>
            </Border.RenderTransform>

            <StackPanel>
                <!-- Uygulama İkonu + Adı -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Image x:Name="OverlayAppIcon"
                           Width="48" Height="48"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />
                    <TextBlock x:Name="OverlayAppName"
                               Text="Uygulama Adı"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="OverlayPromptText"
                               Text="Bu uygulama kilitli. Devam etmek için şifreni gir."
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeS}"
                               TextAlignment="Center"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- ─── PIN Giriş Alanı ─── -->
                <StackPanel x:Name="PinInputArea" Visibility="Visible">
                    <!-- PIN Noktaları (görsel gösterim) -->
                    <StackPanel x:Name="PinDotsPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20">
                        <!-- Dinamik olarak doldurulur -->
                    </StackPanel>

                    <!-- Sayısal Tuş Takımı -->
                    <Grid x:Name="PinPadGrid" HorizontalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Satır 1: 1 2 3 -->
                        <Button x:Name="BtnPin1" Content="1" Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />
                        <Button x:Name="BtnPin2" Content="2" Grid.Row="0" Grid.Column="1"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />
                        <Button x:Name="BtnPin3" Content="3" Grid.Row="0" Grid.Column="2"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />

                        <!-- Satır 2: 4 5 6 -->
                        <Button x:Name="BtnPin4" Content="4" Grid.Row="1" Grid.Column="0"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />
                        <Button x:Name="BtnPin5" Content="5" Grid.Row="1" Grid.Column="1"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />
                        <Button x:Name="BtnPin6" Content="6" Grid.Row="1" Grid.Column="2"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />

                        <!-- Satır 3: 7 8 9 -->
                        <Button x:Name="BtnPin7" Content="7" Grid.Row="2" Grid.Column="0"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />
                        <Button x:Name="BtnPin8" Content="8" Grid.Row="2" Grid.Column="1"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />
                        <Button x:Name="BtnPin9" Content="9" Grid.Row="2" Grid.Column="2"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />

                        <!-- Satır 4: ← 0 ✓ -->
                        <Button x:Name="BtnPinBackspace" Content="⌫" Grid.Row="3" Grid.Column="0"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="18" Click="BtnPinBackspace_Click" />
                        <Button x:Name="BtnPin0" Content="0" Grid.Row="3" Grid.Column="1"
                                Style="{StaticResource BtnSecondary}" Width="64" Height="52"
                                Margin="4" FontSize="20" Click="PinButton_Click" />
                        <Button x:Name="BtnPinSubmit" Content="✓" Grid.Row="3" Grid.Column="2"
                                Style="{StaticResource BtnPrimary}" Width="64" Height="52"
                                Margin="4" FontSize="18" Click="BtnPinSubmit_Click" />
                    </Grid>
                </StackPanel>

                <!-- ─── Şifre Giriş Alanı (PIN yerine seçilebilir) ─── -->
                <StackPanel x:Name="PasswordInputArea" Visibility="Collapsed">
                    <PasswordBox x:Name="OverlayPasswordBox"
                                 Style="{StaticResource InputPassword}"
                                 MaxLength="64"
                                 Margin="0,0,0,12"
                                 KeyDown="OverlayPasswordBox_KeyDown" />
                    <Button x:Name="BtnPasswordSubmit"
                            Content="Kilidi Aç"
                            Style="{StaticResource BtnPrimary}"
                            HorizontalAlignment="Stretch"
                            Click="BtnPasswordSubmit_Click" />
                </StackPanel>

                <!-- ─── Hata / Durum Mesajı ─── -->
                <TextBlock x:Name="OverlayStatusText"
                           Text=""
                           Foreground="{StaticResource BrushStatusError}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="{StaticResource FontSizeS}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />

                <!-- ─── Kalan Deneme ve Bekleme ─── -->
                <TextBlock x:Name="OverlayAttemptsText"
                           Text=""
                           Foreground="{StaticResource BrushTextMuted}"
                           FontFamily="{StaticResource FontPrimary}"
                           FontSize="{StaticResource FontSizeXS}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
