<Window x:Class="WinAppLock.UI.Views.LockOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinAppLock Login"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!-- ─── Tam Ekran Karartma Arkaplanı ─── -->
    <Grid x:Name="OverlayBackground">
        <Grid.Background>
            <SolidColorBrush Color="#000000" Opacity="0.5" />
        </Grid.Background>

        <!-- ─── Merkez Auth Dialog Box (Windows 98 Style) ─── -->
        <Border x:Name="AuthCardBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="320"
                Background="{StaticResource BrushRetroFace}"
                BorderThickness="2"
                BorderBrush="{StaticResource BrushRetroHighlight}">
            
            <Border BorderThickness="1,1,2,2" BorderBrush="{StaticResource BrushRetroShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Title Bar -->
                        <RowDefinition Height="22" />
                        <!-- Content Area -->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Title Bar -->
                    <Grid Grid.Row="0" Margin="2,2,2,0">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource RetroTitleActiveStart}" Offset="0" />
                                <GradientStop Color="{StaticResource RetroTitleActiveEnd}" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Icons/lock.png" Width="16" Height="16" Margin="4,0,4,0" RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <TextBlock Text="Application Locked" 
                                     Foreground="White" 
                                     FontFamily="{StaticResource FontRetro}" 
                                     FontSize="{StaticResource FontSizeTitle}"
                                     FontWeight="Bold"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="12">
                        <!-- App Info Section -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image x:Name="OverlayAppIcon" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock x:Name="OverlayAppName" Foreground="Black" FontWeight="Bold" FontSize="{StaticResource FontSizeTitle}" />
                                <TextBlock x:Name="OverlayPromptText" Foreground="Black" TextWrapping="Wrap" FontSize="{StaticResource FontSizeNormal}" />
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BrushRetroShadow}" Margin="0,0,0,12" />

                        <!-- PIN Giriş Alanı (Classic Keypad) -->
                        <StackPanel x:Name="PinInputArea" Visibility="Visible">
                            <Border Background="White" BorderThickness="1" BorderBrush="{StaticResource BrushRetroShadow}" 
                                    Height="28" Margin="0,0,0,12">
                                <Border BorderThickness="1" BorderBrush="{StaticResource BrushRetroShadow}" SnapsToDevicePixels="True">
                                    <!-- PIN Noktaları -->
                                    <StackPanel x:Name="PinDotsPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Border>

                            <Grid x:Name="PinPadGrid" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnPin1" Content="1" Grid.Row="0" Grid.Column="0" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPin2" Content="2" Grid.Row="0" Grid.Column="1" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPin3" Content="3" Grid.Row="0" Grid.Column="2" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPin4" Content="4" Grid.Row="1" Grid.Column="0" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPin5" Content="5" Grid.Row="1" Grid.Column="1" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPin6" Content="6" Grid.Row="1" Grid.Column="2" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPin7" Content="7" Grid.Row="2" Grid.Column="0" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPin8" Content="8" Grid.Row="2" Grid.Column="1" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPin9" Content="9" Grid.Row="2" Grid.Column="2" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPinBackspace" Content="⌫" Grid.Row="3" Grid.Column="0" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="BtnPinBackspace_Click" />
                                <Button x:Name="BtnPin0" Content="0" Grid.Row="3" Grid.Column="1" Style="{StaticResource BtnRetro}" Width="40" Height="32" Margin="2" Click="PinButton_Click" />
                                <Button x:Name="BtnPinSubmit" Content="OK" Grid.Row="3" Grid.Column="2" Style="{StaticResource BtnRetro}" FontWeight="Bold" Width="40" Height="32" Margin="2" Click="BtnPinSubmit_Click" />
                            </Grid>
                        </StackPanel>

                        <!-- Şifre Giriş Alanı -->
                        <StackPanel x:Name="PasswordInputArea" Visibility="Collapsed">
                            <Border Background="White" BorderThickness="1" BorderBrush="{StaticResource BrushRetroShadow}" Margin="0,0,0,10">
                                <PasswordBox x:Name="OverlayPasswordBox" BorderThickness="0" Background="Transparent"
                                             MaxLength="64" KeyDown="OverlayPasswordBox_KeyDown" Padding="4" />
                            </Border>
                            <Button x:Name="BtnPasswordSubmit" Content="Unlock" Style="{StaticResource BtnRetro}" FontWeight="Bold" Height="26" Click="BtnPasswordSubmit_Click" />
                        </StackPanel>

                        <TextBlock x:Name="OverlayStatusText" Foreground="Red" FontSize="10" TextAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" />
                        
                        <!-- Footer Buttons -->
                        <Grid Margin="0,16,0,0">
                            <TextBlock x:Name="OverlayAttemptsText" VerticalAlignment="Center" Foreground="#444" FontSize="9" />
                            <Button x:Name="BtnCancel" Content="İptal" HorizontalAlignment="Right" Style="{StaticResource BtnRetro}" Width="60" Height="22" Click="BtnCancel_Click" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
