<UserControl x:Class="WinAppLock.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <!--
    ═══════════════════════════════════════════════════
    SettingsView: Ayarlar sayfası.
    MainWindow içinde DashboardContent yerine gösterilir.
    ═══════════════════════════════════════════════════
    -->

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,24">

            <!-- ─── Başlık ─── -->
            <TextBlock x:Name="SettingsTitle" Text="⚙️  Ayarlar"
                       Foreground="{StaticResource BrushTextPrimary}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontSizeXL}"
                       FontWeight="Bold" Margin="0,0,0,24" />

            <!-- ═══ Güvenlik Ayarları ═══ -->
            <TextBlock Text="GÜVENLİK"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontSizeS}"
                       FontWeight="SemiBold" Margin="0,0,0,8" />

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Şifre Değiştir"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="{StaticResource FontSizeMD}" FontWeight="SemiBold" />
                        <TextBlock Text="Master şifreni veya PIN'ini değiştir"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button x:Name="BtnChangePassword" Grid.Column="1"
                            Content="Değiştir"
                            Style="{StaticResource BtnSecondary}"
                            VerticalAlignment="Center"
                            Click="BtnChangePassword_Click" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Hatalı Giriş Limiti"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="{StaticResource FontSizeMD}" FontWeight="SemiBold" />
                        <TextBlock Text="Limiti aşınca geçici bloklama uygula"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox x:Name="TxtMaxAttempts"
                                 Style="{StaticResource InputText}"
                                 Width="50" Text="5"
                                 TextAlignment="Center" />
                        <TextBlock Text=" deneme"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}"
                                   VerticalAlignment="Center" Margin="4,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Bekleme Süresi"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="{StaticResource FontSizeMD}" FontWeight="SemiBold" />
                        <TextBlock Text="Limit aşıldığında kaç saniye beklenecek"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox x:Name="TxtCooldown"
                                 Style="{StaticResource InputText}"
                                 Width="50" Text="30"
                                 TextAlignment="Center" />
                        <TextBlock Text=" sn"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}"
                                   VerticalAlignment="Center" Margin="4,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="UI Zaman Aşımı"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="{StaticResource FontSizeMD}" FontWeight="SemiBold" />
                        <TextBlock Text="İşlem yapılmadığında tekrar şifre sor"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox x:Name="TxtUiTimeout"
                                 Style="{StaticResource InputText}"
                                 Width="50" Text="30"
                                 TextAlignment="Center" />
                        <TextBlock Text=" sn"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="{StaticResource FontSizeS}"
                                   VerticalAlignment="Center" Margin="4,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Genel Ayarlar ═══ -->
            <TextBlock Text="Genel"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontSizeS}"
                       FontWeight="SemiBold" Margin="0,0,0,8" />

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Ses Efektleri"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="{StaticResource FontSizeMD}" FontWeight="SemiBold" />
                        <TextBlock Text="Doğru/yanlış giriş sesi"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,2,0,0" />
                    </StackPanel>
                    <ToggleButton x:Name="ToggleSoundEnabled" Grid.Column="1"
                                  Style="{StaticResource ToggleSwitch}"
                                  IsChecked="True"
                                  VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Windows Başlangıcında Çalış"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="{StaticResource FontSizeMD}" FontWeight="SemiBold" />
                        <TextBlock Text="Bilgisayar açıldığında otomatik başlat"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,2,0,0" />
                    </StackPanel>
                    <ToggleButton x:Name="ToggleStartWithWindows" Grid.Column="1"
                                  Style="{StaticResource ToggleSwitch}"
                                  IsChecked="True"
                                  VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Dil / Language"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="{StaticResource FontSizeMD}" FontWeight="SemiBold" />
                        <TextBlock Text="Arayüz dilini değiştir"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="{StaticResource FontSizeS}" Margin="0,2,0,0" />
                    </StackPanel>
                    <ComboBox x:Name="ComboLanguage" Grid.Column="1"
                              Width="120" VerticalAlignment="Center"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Türkçe" />
                        <ComboBoxItem Content="English" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- ═══ Hakkında ═══ -->
            <TextBlock Text="Hakkında"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontFamily="{StaticResource FontPrimary}"
                       FontSize="{StaticResource FontSizeS}"
                       FontWeight="SemiBold" Margin="0,0,0,8" />

            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="WinAppLock v0.0.100"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="{StaticResource FontSizeMD}" FontWeight="SemiBold" />
                    <TextBlock Text="FOSS — GNU General Public License v3.0"
                               Foreground="{StaticResource BrushTextMuted}"
                               FontSize="{StaticResource FontSizeS}" Margin="0,4,0,4" />
                    <TextBlock Text="github.com/aybrkaknc/winapplock"
                               Foreground="{StaticResource BrushAccentSecondary}"
                               FontSize="{StaticResource FontSizeS}"
                               Cursor="Hand"
                               MouseLeftButtonDown="GithubLink_Click" />
                </StackPanel>
            </Border>

            <!-- Kaydet Butonu -->
            <Button x:Name="BtnSaveSettings"
                    Content="💾  Ayarları Kaydet"
                    Style="{StaticResource BtnPrimary}"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0"
                    Click="BtnSaveSettings_Click" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
