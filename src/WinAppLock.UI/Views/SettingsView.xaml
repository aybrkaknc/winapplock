<UserControl x:Class="WinAppLock.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="10">
        <TabControl Style="{StaticResource RetroTabs}">
            
            <!-- ═══ 1. GÜVENLİK (Security) ═══ -->
            <TabItem Header="{DynamicResource Str_Security}">
                <StackPanel Margin="0,10,0,0">
                    <GroupBox Header="{DynamicResource Str_ChangePasswordTitle}" Margin="0,0,0,10">
                        <StackPanel Margin="5">
                            <TextBlock Text="{DynamicResource Str_ChangePasswordDesc}" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="Black" />
                            <Button x:Name="BtnChangePassword" Content="{DynamicResource Str_BtnChange}" Style="{StaticResource BtnRetro}" HorizontalAlignment="Left" Click="BtnChangePassword_Click" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Sınırlar ve Süreler" Margin="0,0,0,10">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Str_MaxAttemptsTitle}" VerticalAlignment="Center" Foreground="Black" />
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtMaxAttempts" Width="40" Margin="0,2" Text="5" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Str_CooldownTitle}" VerticalAlignment="Center" Foreground="Black" />
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtCooldown" Width="40" Margin="0,2" Text="30" />
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- ═══ 2. GÖRÜNÜM (Appearance - YENİ!) ═══ -->
            <TabItem Header="Görünüm">
                <StackPanel Margin="0,10,0,0">
                    <GroupBox Header="Tema Motoru">
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Ana Tema:" VerticalAlignment="Center" Foreground="Black" />
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ComboThemeBase" Margin="0,2">
                                <ComboBoxItem Content="Dark Retro (Vırtual)" IsSelected="True" />
                                <ComboBoxItem Content="Classic Light" />
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="Navigasyon Stili:" VerticalAlignment="Center" Foreground="Black" />
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ComboNavStyle" Margin="0,2">
                                <ComboBoxItem Content="Sekmeli (Önerilen)" IsSelected="True" />
                                <ComboBoxItem Content="Kenar Çubuğu" />
                            </ComboBox>

                            <TextBlock Grid.Row="2" Text="Animasyonlar:" VerticalAlignment="Center" Foreground="Black" />
                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboAnimations" Margin="0,2">
                                <ComboBoxItem Content="Anında (Win98)" IsSelected="True" />
                                <ComboBoxItem Content="Yumuşak (Vite)" />
                            </ComboBox>

                            <TextBlock Grid.Row="3" Text="Başlık Çubuğu:" VerticalAlignment="Center" Foreground="Black" />
                            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ComboTitleGradient" Margin="0,2">
                                <ComboBoxItem Content="Düz Geçiş (Smooth)" IsSelected="True" />
                                <ComboBoxItem Content="8-bit Klasik" />
                            </ComboBox>

                            <TextBlock Grid.Row="4" Text="İkon Seti:" VerticalAlignment="Center" Foreground="Black" />
                            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="ComboIconSet" Margin="0,2">
                                <ComboBoxItem Content="Orijinal 98" IsSelected="True" />
                                <ComboBoxItem Content="Modernize" />
                            </ComboBox>
                        </Grid>
                    </GroupBox>
                    
                    <CheckBox x:Name="CheckSoundEffects" Content="Sistem ses efektlerini kullan (Startup/Error)" Margin="5,10,0,0" IsChecked="True" Foreground="Black" />
                </StackPanel>
            </TabItem>

            <!-- ═══ 3. GENEL (General) ═══ -->
            <TabItem Header="{DynamicResource Str_General}">
                <StackPanel Margin="0,10,0,0">
                    <GroupBox Header="Sistem Arabirimi">
                        <StackPanel Margin="5">
                            <CheckBox x:Name="CheckStartWithWindows" Content="{DynamicResource Str_AutostartTitle}" IsChecked="True" Foreground="Black" />
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Str_Language}" VerticalAlignment="Center" Foreground="Black" />
                                <ComboBox Grid.Column="1" x:Name="ComboLanguage" SelectedIndex="0" SelectionChanged="ComboLanguage_SelectionChanged">
                                    <ComboBoxItem Content="Türkçe" />
                                    <ComboBoxItem Content="English" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource Str_About}" Margin="0,10,0,0">
                        <StackPanel Margin="5">
                            <TextBlock Text="WinAppLock v0.0.102" FontWeight="Bold" Foreground="Black" />
                            <TextBlock Text="Açık Kaynak (GPLv3)" Margin="0,2" Foreground="Black" />
                            <TextBlock Text="github.com/aybrkaknc/winapplock" Foreground="Blue" Cursor="Hand" TextDecorations="Underline" MouseLeftButtonDown="GithubLink_Click" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>
            
        </TabControl>

        <Button x:Name="BtnSaveSettings"
                Grid.Row="1"
                Content="Uygula"
                Style="{StaticResource BtnRetro}"
                Width="80" Height="24"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,0,0"
                Click="BtnSaveSettings_Click" />
    </Grid>
</UserControl>
