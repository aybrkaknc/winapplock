<Window x:Class="WinAppLock.UI.Views.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str_SetupTitle}"
        Width="520" Height="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <!--
    ═══════════════════════════════════════════════════
    SetupWizard: İlk çalıştırma kurulum sihirbazı.
    
    Adımlar:
    1. Hoş Geldin + Dil Seçimi
    2. Kimlik Doğrulama Yöntemi (PIN / Şifre)
    3. Master Password Belirleme
    4. Recovery Key Gösterimi
    5. Güvenlik Sorusu (Opsiyonel)
    ═══════════════════════════════════════════════════
    -->

    <Border x:Name="WizardBorder"
            Background="{StaticResource BrushBackgroundDarkest}"
            CornerRadius="{StaticResource RadiusLarge}"
            BorderBrush="{StaticResource BrushBorderDefault}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ─── Wizard Header ─── -->
            <Border Grid.Row="0" Background="{StaticResource BrushBackgroundDark}"
                    Padding="24,16" MouseLeftButtonDown="WizardHeader_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock x:Name="WizardTitle" Text="{DynamicResource Str_SetupTitle}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" />
                    <TextBlock x:Name="WizardStepText" Text="Adım 1/5 — Hoş Geldin"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeS}"
                               Margin="0,4,0,0" />
                    <!-- İlerleme Çubuğu -->
                    <Grid Margin="0,12,0,0" Height="4">
                        <Border Background="{StaticResource BrushBackgroundLight}"
                                CornerRadius="2" />
                        <Border x:Name="WizardProgressBar"
                                Background="{StaticResource BrushAccentGradient}"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                Width="104" /> <!-- 520 * 1/5 = 104 -->
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── Wizard Content (Sayfa değişimi) ─── -->
            <Grid Grid.Row="1" Margin="32,24,32,24">

                <!-- ═══ ADIM 1: Hoş Geldin + Dil ═══ -->
                <StackPanel x:Name="Step1Welcome" Visibility="Visible">
                    <TextBlock Text="🛡️" FontSize="48" HorizontalAlignment="Center"
                               Margin="0,8,0,16" />
                    <TextBlock Text="{DynamicResource Str_SetupWelcomeTitle}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXXL}"
                               FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="{DynamicResource Str_SetupWelcomeDesc}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               TextAlignment="Center" Margin="0,12,0,32"
                               LineHeight="22" />

                    <TextBlock Text="{DynamicResource Str_Language}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <RadioButton x:Name="RadioLangTR" Content="{DynamicResource Str_LangTR}"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontFamily="{StaticResource FontPrimary}"
                                     FontSize="{StaticResource FontSizeMD}"
                                     IsChecked="True" Margin="0,0,24,0"
                                     VerticalContentAlignment="Center" />
                        <RadioButton x:Name="RadioLangEN" Content="{DynamicResource Str_LangEN}"
                                     Foreground="{StaticResource BrushTextPrimary}"
                                     FontFamily="{StaticResource FontPrimary}"
                                     FontSize="{StaticResource FontSizeMD}"
                                     VerticalContentAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- ═══ ADIM 2: Doğrulama Yöntemi ═══ -->
                <StackPanel x:Name="Step2AuthMethod" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str_LockMethod}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="{DynamicResource Str_LockMethodDesc}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               Margin="0,0,0,24"  />

                    <!-- PIN Seçeneği -->
                    <Border x:Name="CardAuthPin" Style="{StaticResource CardPanel}"
                            Margin="0,0,0,12" Cursor="Hand"
                            MouseLeftButtonDown="CardAuthPin_Click">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_PinCode}"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeLG}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource Str_PinCodeDesc}"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Şifre Seçeneği -->
                    <Border x:Name="CardAuthPassword" Style="{StaticResource CardPanel}"
                            Cursor="Hand"
                            MouseLeftButtonDown="CardAuthPassword_Click">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Str_Password}"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeLG}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource Str_PasswordDesc}"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontFamily="{StaticResource FontPrimary}"
                                       FontSize="{StaticResource FontSizeS}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- PIN Uzunluk Seçici (PIN seçildiğinde görünür) -->
                    <StackPanel x:Name="PinLengthSelector" Visibility="Collapsed"
                                Margin="0,16,0,0">
                        <TextBlock Text="{DynamicResource Str_PinLength}"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontFamily="{StaticResource FontPrimary}"
                                   FontSize="{StaticResource FontSizeMD}"
                                   FontWeight="SemiBold" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <RadioButton x:Name="RadioPin4" Content="  4"
                                         Foreground="{StaticResource BrushTextPrimary}"
                                         FontSize="{StaticResource FontSizeMD}" Margin="0,0,16,0"
                                         VerticalContentAlignment="Center" />
                            <RadioButton x:Name="RadioPin5" Content="  5"
                                         Foreground="{StaticResource BrushTextPrimary}"
                                         FontSize="{StaticResource FontSizeMD}" Margin="0,0,16,0"
                                         VerticalContentAlignment="Center" />
                            <RadioButton x:Name="RadioPin6" Content="  6"
                                         Foreground="{StaticResource BrushTextPrimary}"
                                         FontSize="{StaticResource FontSizeMD}" Margin="0,0,16,0"
                                         IsChecked="True"
                                         VerticalContentAlignment="Center" />
                            <RadioButton x:Name="RadioPin7" Content="  7"
                                         Foreground="{StaticResource BrushTextPrimary}"
                                         FontSize="{StaticResource FontSizeMD}" Margin="0,0,16,0"
                                         VerticalContentAlignment="Center" />
                            <RadioButton x:Name="RadioPin8" Content="  8"
                                         Foreground="{StaticResource BrushTextPrimary}"
                                         FontSize="{StaticResource FontSizeMD}"
                                         VerticalContentAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- ═══ ADIM 3: Şifre/PIN Belirleme ═══ -->
                <StackPanel x:Name="Step3SetPassword" Visibility="Collapsed">
                    <TextBlock x:Name="Step3Title" Text="{DynamicResource Str_MasterSetTitle}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock x:Name="Step3Description"
                               Text="{DynamicResource Str_MasterSetDesc}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               Margin="0,0,0,24" />

                    <TextBlock Text="{DynamicResource Str_SetupPasswordTitle}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4" />
                    <PasswordBox x:Name="SetupPasswordBox1"
                                 Style="{StaticResource InputPassword}"
                                 Margin="0,0,0,12" />

                    <TextBlock Text="{DynamicResource Str_SetupPasswordConfirm}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4" />
                    <PasswordBox x:Name="SetupPasswordBox2"
                                 Style="{StaticResource InputPassword}"
                                 Margin="0,0,0,8" />

                    <TextBlock x:Name="SetupPasswordError" Text=""
                               Foreground="{StaticResource BrushStatusError}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeS}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- ═══ ADIM 4: Recovery Key ═══ -->
                <StackPanel x:Name="Step4RecoveryKey" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str_RecoveryKeyTitle}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="{DynamicResource Str_RecoveryKeyDesc}"
                               Foreground="{StaticResource BrushStatusWarning}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               TextWrapping="Wrap" LineHeight="22"
                               Margin="0,0,0,20" />

                    <Border Background="{StaticResource BrushBackgroundDark}"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="20,16" Margin="0,0,0,16"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="RecoveryKeyDisplay"
                                   Text="WAL-XXXX-XXXX-XXXX-XXXX"
                                   Foreground="{StaticResource BrushAccentSecondary}"
                                   FontFamily="{StaticResource FontMono}"
                                   FontSize="{StaticResource FontSizeXL}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Button x:Name="BtnCopyRecoveryKey"
                            Content="{DynamicResource Str_BtnCopy}"
                            Style="{StaticResource BtnSecondary}"
                            HorizontalAlignment="Center"
                            Click="BtnCopyRecoveryKey_Click" />
                </StackPanel>

                <!-- ═══ ADIM 5: Güvenlik Sorusu (Opsiyonel) ═══ -->
                <StackPanel x:Name="Step5SecurityQuestion" Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource Str_SecurityQuestionTitle}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeXL}"
                               FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBlock Text="{DynamicResource Str_SecurityQuestionDesc}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontFamily="{StaticResource FontPrimary}"
                               FontSize="{StaticResource FontSizeMD}"
                               Margin="0,0,0,20" LineHeight="22" />

                    <TextBlock Text="{DynamicResource Str_SecurityQuestion}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4" />
                    <TextBox x:Name="SecurityQuestionBox"
                             Style="{StaticResource InputText}"
                             Margin="0,0,0,12" />

                    <TextBlock Text="{DynamicResource Str_SecurityAnswer}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="{StaticResource FontSizeS}" Margin="0,0,0,4" />
                    <TextBox x:Name="SecurityAnswerBox"
                             Style="{StaticResource InputText}" />
                </StackPanel>
            </Grid>

            <!-- ─── Wizard Footer (Geri / İleri) ─── -->
            <Border Grid.Row="2" Background="{StaticResource BrushBackgroundDark}"
                    Padding="24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnWizardBack" Grid.Column="0"
                            Content="{DynamicResource Str_BtnBack}"
                            Style="{StaticResource BtnSecondary}"
                            HorizontalAlignment="Left"
                            Click="BtnWizardBack_Click"
                            Visibility="Collapsed" />

                    <Button x:Name="BtnWizardSkip" Grid.Column="1"
                            Content="{DynamicResource Str_BtnSkip}"
                            Style="{StaticResource BtnSecondary}"
                            Margin="0,0,8,0"
                            Click="BtnWizardSkip_Click"
                            Visibility="Collapsed" />

                    <Button x:Name="BtnWizardNext" Grid.Column="2"
                            Content="{DynamicResource Str_BtnNext}"
                            Style="{StaticResource BtnPrimary}"
                            HorizontalAlignment="Right"
                            Click="BtnWizardNext_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
